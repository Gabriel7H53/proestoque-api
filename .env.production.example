# Variáveis de Ambiente para Produção (Railway)
NODE_ENV="production"
PORT=3333

# URL de conexão com a base de dados PostgreSQL fornecida pelo Railway
# Exemplo: postgresql://postgres:senha@containers-us-west-1.railway.app:5432/railway
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:PORTA/BANCO"

# Segredos de Autenticação JWT
JWT_SECRET="insira-aqui-uma-chave-jwt-ultra-secreta-e-longa-para-producao"
JWT_EXPIRES_IN="7d"
